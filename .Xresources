Xft.dpi: 120

XTerm.vt100.faceName: xft:GoMono Nerd Font:size=11:antialias=true:style=Regular
Xterm.saveLines: 2000
XTerm.vt100.locale: false
XTerm.vt100.utf8: true
xterm.VT100.Translations: #override \
    <Btn1Up>: select-end(PRIMARY, CLIPBOARD, CUT_BUFFER0) \n\
    Shift Ctrl <Key> V: insert-selection(CLIPBOARD, CUT_BUFFER0, PRIMARY)
XTerm.vt100.backarrowKey: false
XTerm.ttyModes: erase ^?
XTerm.termName: xterm-256color

Xcursor.theme: capitaine-cursors
Xcursor.size: 16

URxvt*font: xft:Hack Nerd Font:size=11:style=Regular
! URxvt*background: #1d2021
! URxvt*foreground: gray
URxvt*saveLines: 2000 
URxvt*scrollBar:  false
URxvt*perl-ext: 
URxvt*perl-ext-common:

